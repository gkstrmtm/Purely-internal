Right now that decision hinges on the heuristics in `planPuraActions` (notably the gate to the “HARD OVERRIDE” re-run). If those heuristics miss common imperative phrasing, you’ll keep seeing “it didn’t do it” behavior even when the model could have executed.

### Code change: harden imperative detection (no “allow more BS”; force correct mode selection)

````ts
import { z } from "zod";

import { generateText, generateTextWithImages } from "@/lib/ai";
import {
  PortalAgentActionKeySchema,
  extractJsonObject,
  portalAgentActionsIndexText,
  type PortalAgentActionKey,
} from "@/lib/portalAgentActions";
import { SCHEDULED_ACTION_PREFIX } from "@/lib/portalAiChatScheduledActionEnvelope";

export type PuraPlannerMode = "execute" | "clarify" | "explain" | "noop";

function normalizeUserTextForIntent(textRaw: string): string {
  return String(textRaw || "")
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, 2000);
}

function userExplicitlyWantsAgentToDoIt(textRaw: string): boolean {
  const t = normalizeUserTextForIntent(textRaw).toLowerCase();

  // Strong “do it now” signals (even if phrased as a question).
  if (/\b(do it|do that|handle it|take care of it|go ahead|please do|can you do|could you do)\b/.test(t)) return true;

  // Common portal-work verbs. This is intentionally broad; it’s *mode* selection,
  // not action selection (the planner schema + executor still constrain actions).
  const verb = /\b(create|build|set up|setup|configure|enable|turn on|disable|turn off|update|change|edit|fix|remove|delete|add|send|publish|sync|import|export|generate)\b/;
  if (verb.test(t)) {
    // If it’s “can you <verb> …” that’s still an imperative in practice.
    if (/\b(can you|could you|please|go ahead and|i want you to|i need you to)\b/.test(t)) return true;

    // Also treat leading verbs as imperative: "Create a funnel...", "Update booking..."
    if (new RegExp(`^(?:please\\s+)?${verb.source}`).test(t)) return true;

    // And treat short command-like sentences as imperative even without “please”.
    // Example: "Fix our booking form." / "Update funnel home page copy."
    if (t.split(" ").length <= 14) return true;
  }

  return false;
}

function userAsksForHowOrSteps(textRaw: string): boolean {
  const t = normalizeUserTextForIntent(textRaw).toLowerCase();

  // Clear “teach me / instructions” intent.
  if (/\bhow do i\b/.test(t)) return true;
  if (/\bwhere do i\b/.test(t)) return true;
  if (/\bwhat do i click\b/.test(t)) return true;
  if (/\bhow can i\b/.test(t)) return true;
  if (/\bsteps?\b/.test(t) && /\b(show|give|share|walk me through|tell me)\b/.test(t)) return true;

  return false;
}

function looksLikeImperativeRequest(textRaw: string): boolean {
  // This is used to trigger the HARD OVERRIDE re-run.
  // Make it at least as strong as userExplicitlyWantsAgentToDoIt.
  const t = normalizeUserTextForIntent(textRaw);

  if (userExplicitlyWantsAgentToDoIt(t)) return true;

  // Additional command-like patterns that often lack “please”.
  // Examples: "Add a form to my funnel", "Move this page above pricing"
  if (/^(?:add|remove|delete|update|change|edit|fix|create|build|configure|enable|disable|turn on|turn off)\b/i.test(t)) return true;

  return false;
}

