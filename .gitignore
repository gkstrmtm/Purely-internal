# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# tooling artifacts
.eslint-report*.json
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.npmrc

# local dev database
*.db
*.db-journal

# local uploads (ephemeral on most hosts)
/public/uploads/

# local notes / chat transcripts
/src/lib/notes/

# local chat transcript at repo root
/chathistory

# additional local chat history file
/chat history updated.md

# additional local chat history file (copilot transcript)
/User: can you stage commit and push the .md

# local-only Copilot context (do not commit)
/newchathistory.md

# local-only Copilot context (do not commit)
/newnewchathistory

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
