{
  "name": "purely-automation",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/prisma-prebuild.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "check:copy": "node scripts/check-no-em-dash.mjs",
    "portal:inventory": "node scripts/generate-portal-api-inventory.mjs",
    "portal:master-checklist": "node scripts/generate-portal-ai-master-checklist.mjs",
    "lint": "npm run check:copy && eslint",
    "test:twilio-mms-smoke": "node scripts/twilio-mms-smoke.mjs",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "node scripts/db-guard.mjs && prisma db push",
    "db:migrate": "node scripts/db-guard.mjs && prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:deploy": "node scripts/db-guard.mjs && prisma db push && prisma db seed",
    "db:patch:hr": "node scripts/apply-hr-db-patch.mjs",
    "db:patch:blogs": "node scripts/apply-blogs-db-patch.mjs",
    "vercel-build": "node scripts/prisma-prebuild.mjs && next build --webpack",
    "blogs:cleanup-asterisks": "node prisma/cleanup-blog-asterisks.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "@vercel/blob": "^2.3.1",
    "authorizenet": "^1.0.10",
    "bcryptjs": "^3.0.3",
    "braintree": "^3.36.0",
    "expo-server-sdk": "^6.1.0",
    "luxon": "^3.7.2",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-easy-crop": "^5.5.6",
    "react-grid-layout": "^2.2.2",
    "react-markdown": "^10.1.0",
    "react-resizable": "^3.1.3",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
