# Mobile app only (Expo public env vars)
# Optional (recommended only for native/dev). Leave unset for the web build so it
# uses same-origin requests + `vercel.json` rewrites (required for cookie sessions).
# EXPO_PUBLIC_API_BASE_URL=https://purelyautomation.com

# Optional: override where the logo image is served from.
# EXPO_PUBLIC_PORTAL_LOGO_BASE_URL=https://purelyautomation.com
