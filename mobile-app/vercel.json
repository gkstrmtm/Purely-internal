{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run web",
  "rewrites": [
    {
      "source": "/brand/:path*",
      "destination": "https://purelyautomation.com/brand/:path*"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://purelyautomation.com/_next/:path*"
    },
    {
      "source": "/portal/api/:path*",
      "destination": "https://purelyautomation.com/portal/api/:path*"
    },
    {
      "source": "/portal/:path*",
      "destination": "https://purelyautomation.com/portal/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://purelyautomation.com/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
